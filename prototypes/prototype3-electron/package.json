{
  "name": "gertrude-shell",
  "version": "1.0.0",
  "description": "Gertrude Shell — an accessible Windows shell replacement for a 103-year-old woman",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["electron", "accessibility", "shell", "windows"],
  "author": "Gertrude Shell Team",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.3.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
